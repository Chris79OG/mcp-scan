{
  "name": "@syntrophy/mcp-scan-api",
  "version": "0.1.0",
  "description": "REST API server for mcp-scan — trigger scans, retrieve results, and receive webhooks",
  "main": "./dist/server.js",
  "types": "./dist/server.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/server.ts",
    "start": "node dist/server.js",
    "test": "jest --config jest.config.js",
    "test:integration": "jest --config jest.config.js --testPathPattern=integration"
  },
  "keywords": ["mcp", "security", "scanner", "api", "rest"],
  "author": "Syntrophy Foundry",
  "license": "MIT",
  "dependencies": {
    "@syntrophy/mcp-scan": "file:..",
    "express": "^4.19.2",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.0.0",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^9.0.8",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
