# Staging environment configuration
# Copy to /opt/mcp-scan/staging.env on the staging server — never commit the real file.

# Server port (default: 3000)
PORT=3000

# Log level: debug | info | warn | error (default: info)
LOG_LEVEL=info

# (Optional) restrict /scan endpoint to requests from known CIDR ranges
# SCAN_ALLOWED_CIDR=10.0.0.0/8

# Sentry DSN for error reporting (leave empty to disable)
SENTRY_DSN=

# Environment tag embedded in structured log lines
NODE_ENV=staging
