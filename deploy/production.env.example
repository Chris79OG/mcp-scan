# Production environment configuration
# Copy to /opt/mcp-scan/production.env on the production server — never commit the real file.

# Server port (default: 3000)
PORT=3000

# Log level: info | warn | error  (debug is too verbose for prod)
LOG_LEVEL=info

# (Optional) restrict /scan endpoint to requests from known CIDR ranges
# SCAN_ALLOWED_CIDR=10.0.0.0/8

# Sentry DSN for error reporting
SENTRY_DSN=https://YOUR_SENTRY_DSN@sentry.io/PROJECT_ID

# Environment tag embedded in structured log lines
NODE_ENV=production
